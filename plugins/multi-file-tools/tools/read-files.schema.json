{
  "type": "object",
  "properties": {
    "paths": {
      "type": "array",
      "description": "List of absolute file paths to read",
      "items": {
        "type": "string",
        "format": "file-path"
      },
      "minItems": 1,
      "maxItems": 20
    },
    "maxSizeKb": {
      "type": "integer",
      "description": "Skip files larger than this size in KB. Defaults to 500.",
      "default": 500,
      "minimum": 1,
      "maximum": 10000
    }
  },
  "required": ["paths"]
}
